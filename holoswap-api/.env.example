# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/holoswap
DATABASE_SSL=false

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here

# Server Configuration
PORT=3000
CORS_ORIGIN=*

# Royal Mail API
ROYAL_MAIL_API_KEY=your_royal_mail_api_key_here

# PokePulse API Keys
POKEPULSE_CATALOGUE_KEY=your_catalogue_api_key_here
POKEPULSE_MARKET_KEY=your_market_data_api_key_here

# Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# SMTP (Office 365) — for emailing vendor submission notifications
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your@domain.com
SMTP_PASS=your-password
SMTP_FROM=your@domain.com
